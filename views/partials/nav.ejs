<nav class="bg-white/90 backdrop-blur-sm border-b border-gray-200 sticky top-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16 items-center">
      
      <a href="/" class="text-2xl font-extrabold text-gray-900 tracking-tighter hover:text-blue-600 transition">BlogiFy</a>

      <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg text-gray-700 hover:bg-gray-100 focus:outline-none transition">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
      </button>

      <div class="hidden md:flex items-center space-x-1">
        <a href="/" class="px-4 py-2 rounded-lg font-medium text-gray-600 hover:bg-gray-100 transition <%= (locals.path === '/') ? 'bg-gray-900 text-white hover:bg-gray-800' : '' %>">Home</a>
        
        <% if (locals.user) { %>
          <a href="/blog/add-new" class="px-4 py-2 rounded-lg font-medium text-gray-600 hover:bg-gray-100 transition <%= (locals.path === '/blog/add-new') ? 'bg-gray-900 text-white hover:bg-gray-800' : '' %>">Add Blog</a>
          
          <div class="relative group ml-4">
            <button class="flex items-center space-x-2 px-4 py-2 rounded-lg bg-gray-50 border border-gray-200 hover:border-gray-300 transition">
              <span class="font-medium text-gray-700"><%= locals.user.name || "My Account" %></span>
              <svg class="w-4 h-4 text-gray-500 group-hover:rotate-180 transition-transform duration-300" fill="currentColor" viewBox="0 0 20 20"><path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg>
            </button>
            <div class="absolute right-0 mt-2 w-48 bg-white border border-gray-100 rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform translate-y-2 group-hover:translate-y-0 p-2">
              <a href="/user/logout" class="flex items-center px-4 py-2 text-sm text-red-600 hover:bg-red-50 rounded-lg transition">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                Log Out
              </a>
            </div>
          </div>
        <% } else { %>
          <a href="/user/signup" class="text-gray-600 hover:text-blue-600 font-medium px-4 py-2 transition">Sign Up</a>
          <a href="/user/signin" class="bg-gray-900 text-white px-6 py-2 rounded-lg font-medium hover:bg-black transition transform active:scale-95 ml-2">Sign In</a>
        <% } %>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 p-4 space-y-1">
    <a href="/" class="block px-4 py-3 rounded-lg hover:bg-gray-50">Home</a>
    <% if (locals.user) { %>
      <a href="/blog/add-new" class="block px-4 py-3 rounded-lg hover:bg-gray-50">Add Blog</a>
      <a href="/user/logout" class="block px-4 py-3 rounded-lg text-red-600 hover:bg-red-50">Log Out</a>
    <% } else { %>
      <a href="/user/signup" class="block px-4 py-3 rounded-lg hover:bg-gray-50">Sign Up</a>
      <a href="/user/signin" class="block px-4 py-3 rounded-lg bg-gray-900 text-white font-bold">Sign In</a>
    <% } %>
  </div>
</nav>

<script>
  document.getElementById('mobile-menu-btn').addEventListener('click', () => { 
    document.getElementById('mobile-menu').classList.toggle('hidden'); 
  });
</script>