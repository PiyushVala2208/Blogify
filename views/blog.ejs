<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title><%= blog.title %> | BlogiFy</title>
</head>
<body class="bg-gray-50">
    <%- include('./partials/nav') %>

    <main class="max-w-4xl mx-auto py-12 px-4">
        <article class="bg-white p-8 md:p-12 rounded-3xl shadow-sm border border-gray-100">
            <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-8 leading-tight"><%= blog.title %></h1>
            
            <div class="flex items-center space-x-3 mb-8">
                <img src="<%= blog.createdBy.profileImageURL %>" class="w-12 h-12 rounded-full border border-gray-200">
                <div>
                    <p class="text-sm font-bold text-gray-900"><%= blog.createdBy.fullname %></p>
                    <p class="text-xs text-gray-500">Author</p>
                </div>
            </div>

            <img src="<%= blog.coverImageURL %>" class="w-full h-80 object-cover rounded-2xl mb-8">
            
            <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed">
                <%= blog.body %>
            </div>
        </article>

        <section class="mt-12 bg-white p-8 rounded-3xl shadow-sm border border-gray-100">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Comments (<%= comment.length %>)</h2>
            
            <% if (locals.user) { %>
                <form action="/blog/comment/<%= blog._id %>" method="post" class="mb-8">
                    <div class="flex gap-4">
                        <input type="text" name="content" required placeholder="Write a comment..." 
                            class="flex-1 px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition">
                        <button type="submit" class="bg-gray-900 text-white px-6 py-3 rounded-xl hover:bg-gray-800 transition">Post</button>
                    </div>
                </form>
            <% } %>

            <div class="space-y-6">
                <% comment.forEach(comment => { %>
                    <div class="flex gap-4 border-b border-gray-50 pb-6 last:border-0">
                        <img src="<%= comment.createdBy.profileImageURL %>" class="w-10 h-10 rounded-full">
                        <div>
                            <p class="text-sm font-bold text-gray-900"><%= comment.createdBy.fullname %></p>
                            <p class="text-gray-700 mt-1"><%= comment.content %></p>
                        </div>
                    </div>
                <% }) %>
            </div>
        </section>
    </main>
</body>
</html>